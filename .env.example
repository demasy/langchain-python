# Copy this file to .env and adjust as needed:  cp .env.example .env

# The local model served by Ollama. Must be pulled first:
#   docker compose exec ollama ollama pull <model>
OLLAMA_MODEL=llama3.2

# Where the app reaches the Ollama server (Compose service DNS name).
OLLAMA_BASE_URL=http://ollama:11434

# Host port mapped to the Ollama container.
OLLAMA_PORT=11434

# Timezone used by the current_time tool.
TZ=Asia/Riyadh
